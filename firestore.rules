rules_version = '2';

// BiteSites Firestore security rules
//
// Threat model / design notes:
//   * `leads` accepts writes from anonymous visitors (the public marketing forms),
//     so every field is whitelisted, type-checked and length-capped. This stops the
//     collection from being used as free object storage.
//   * Nobody can read, edit or delete a lead from the client except an admin. Leads
//     are effectively append-only from the browser.
//   * Roles live in `roles/{uid}`, which NO client can write except an admin. A user
//     signing themselves up can never grant themselves access — self-registration
//     only creates a `users/{uid}` profile with status "pending".
//   * Custom auth claims (set via the Admin SDK) are honoured as a fast path so role
//     checks don't always cost an extra document read.

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------- helpers

    function isSignedIn() {
      return request.auth != null;
    }

    // Role from a custom claim, if one has been set via the Admin SDK.
    function claimRole() {
      return isSignedIn() && 'role' in request.auth.token
        ? request.auth.token.role
        : '';
    }

    // Role from the admin-controlled roles/{uid} document.
    function storedRole() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles/$(request.auth.uid))
        ? get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role
        : '';
    }

    function role() {
      return claimRole() != '' ? claimRole() : storedRole();
    }

    function isAdmin() {
      return role() == 'admin';
    }

    function isClient() {
      return role() == 'client';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ---------------------------------------------------------- lead validation

    function leadRequiredKeys() {
      return [
        'name', 'email', 'businessSize', 'services',
        'preferredContactMethod', 'source', 'status', 'createdAt'
      ];
    }

    function leadAllowedKeys() {
      return [
        'name', 'email', 'phone', 'businessName', 'roleInCompany',
        'businessSize', 'urgencyTag', 'services', 'preferredContactMethod',
        'projectDetails', 'customAnswers', 'source', 'status', 'createdAt',
        'pagePath', 'referrer', 'userAgent'
      ];
    }

    function str(data, field, maxLen) {
      return data[field] is string && data[field].size() > 0 && data[field].size() <= maxLen;
    }

    function optStr(data, field, maxLen) {
      return !(field in data) || (data[field] is string && data[field].size() <= maxLen);
    }

    function validCustomAnswers(answers) {
      return answers is map
        && answers.keys().hasOnly(['services', 'urgencyTag', 'businessSize'])
        && optStr(answers, 'services', 500)
        && optStr(answers, 'urgencyTag', 500)
        && optStr(answers, 'businessSize', 500);
    }

    function validLead(data) {
      return data.keys().hasAll(leadRequiredKeys())
        && data.keys().hasOnly(leadAllowedKeys())

        // Required, human-entered fields.
        && str(data, 'name', 120)
        && str(data, 'email', 200)
        && data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$')

        // Optional, human-entered fields.
        && optStr(data, 'phone', 40)
        && optStr(data, 'businessName', 160)
        && optStr(data, 'roleInCompany', 160)
        && optStr(data, 'projectDetails', 5000)

        // Controlled vocabularies. The client normalises anything unrecognised
        // (e.g. free-text answers typed into the Bit chat) to 'other'.
        && data.businessSize in ['solo', 'small', 'growing', 'established', 'enterprise', 'other']
        && (!('urgencyTag' in data) || data.urgencyTag in ['asap', '2_4_weeks', '1_2_months', 'flexible', 'other', ''])
        && data.preferredContactMethod in ['email', 'phone']
        // Only the two sources a browser can legitimately be. Byte's leads carry
        // source 'byte_voice' and are written by the recordVoiceCall function
        // with the Admin SDK, which bypasses these rules — leaving it out here
        // means a visitor cannot forge a lead that looks like a booked call.
        && data.source in ['intake_form', 'bit_chat']

        && data.services is list
        && data.services.size() >= 1
        && data.services.size() <= 4
        && data.services.hasOnly(['web_development', 'ai_automation', 'social_media_management', 'other'])

        // Free-text chat answers are preserved, but only for the three known
        // Bit questions and only up to 500 chars each — an unbounded map here
        // would let anyone park ~1MB of arbitrary data per document.
        && (!('customAnswers' in data) || validCustomAnswers(data.customAnswers))

        // Server-controlled fields the submitter must not choose.
        && data.status == 'new'
        && data.createdAt == request.time

        // Low-value diagnostic context.
        && optStr(data, 'pagePath', 300)
        && optStr(data, 'referrer', 400)
        && optStr(data, 'userAgent', 400);
    }

    // ------------------------------------------------------------------ leads

    match /leads/{leadId} {
      // Public marketing forms — anyone may submit, nobody may snoop.
      allow create: if validLead(request.resource.data);
      allow read:   if isAdmin();
      allow update: if isAdmin()
                    // Admins triage status/notes but never rewrite history.
                    && request.resource.data.createdAt == resource.data.createdAt
                    && request.resource.data.email == resource.data.email;
      allow delete: if isAdmin();
    }

    // ----------------------------------------------------------------- events
    // First-party analytics written by every visitor (see src/lib/analytics.js).
    // Same threat model as `leads`: anonymous writes, so every field is
    // whitelisted, typed and capped, and nothing can read them back but an admin.
    // Append-only — a visitor cannot revise or erase what they did.

    function validEvent(data) {
      return data.keys().hasAll(['type', 'sid', 'vid', 'path', 'day', 'device', 'ts'])
        && data.keys().hasOnly([
             'type', 'sid', 'vid', 'path', 'day', 'device', 'ts',
             'label', 'section', 'interactive', 'x', 'y', 'vw', 'vh',
             'value', 'referrer', 'query', 'href'
           ])
        // Mirrors EVENT_TYPES in src/lib/analytics.js. A type present there but
        // missing here rejects the entire writeBatch it arrives in, silently
        // discarding every unrelated event batched alongside it — keep the two
        // lists in step, and deploy these rules before the client that emits.
        && data.type in ['page_view', 'click', 'section_view', 'scroll_depth',
                         'form_start', 'form_submit', 'chat_open', 'call_open', 'outbound',
                         'portfolio_project_view', 'portfolio_progress', 'portfolio_video_health']
        && str(data, 'sid', 40)
        && str(data, 'vid', 40)
        && str(data, 'path', 300)
        && data.day is string && data.day.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && data.device in ['mobile', 'tablet', 'desktop']
        && data.ts == request.time

        && optStr(data, 'label', 80)
        && optStr(data, 'section', 60)
        && optStr(data, 'referrer', 400)
        && optStr(data, 'query', 300)
        && optStr(data, 'href', 300)
        && (!('interactive' in data) || data.interactive is bool)
        // Click positions are fractions of the viewport/page, never pixels.
        && (!('x' in data) || (data.x is number && data.x >= 0 && data.x <= 1))
        && (!('y' in data) || (data.y is number && data.y >= 0 && data.y <= 1))
        && (!('vw' in data) || (data.vw is int && data.vw >= 0 && data.vw <= 20000))
        && (!('vh' in data) || (data.vh is int && data.vh >= 0 && data.vh <= 20000))
        && (!('value' in data) || (data.value is number && data.value >= 0 && data.value <= 100000));
    }

    match /events/{eventId} {
      allow create: if validEvent(request.resource.data);
      allow read:   if isAdmin();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ------------------------------------------------- conversations (Bit/Byte)
    // Transcripts of the chat and voice agents. A visitor may open a conversation
    // and append to it, and may close their own out — but only through the narrow
    // update below, which cannot rewrite when it started or who it belonged to,
    // and never gains read access to anyone's conversation including their own.

    function validConversationOpen(data, agentName, channelName) {
      return data.keys().hasAll(['agent', 'channel', 'status', 'startedAt', 'sid', 'path'])
        && data.keys().hasOnly([
             'agent', 'channel', 'status', 'startedAt', 'sid', 'path',
             'referrer', 'userAgent', 'messageCount', 'provider'
           ])
        && data.agent == agentName
        && data.channel == channelName
        && data.status == 'open'
        && data.startedAt == request.time
        && str(data, 'sid', 40)
        && optStr(data, 'path', 300)
        && optStr(data, 'referrer', 400)
        && optStr(data, 'userAgent', 400)
        && optStr(data, 'provider', 60)
        && (!('messageCount' in data) || (data.messageCount is int && data.messageCount >= 0));
    }

    // The close-out. Deliberately not a general update: the immutable fields are
    // compared against what is already stored, so a passer-by cannot reassign a
    // conversation or backdate it, and only terminal states are writable.
    function validConversationClose(data, previous) {
      return data.diff(previous).affectedKeys().hasOnly([
               'status', 'endedAt', 'messageCount', 'durationSec', 'leadId', 'answers', 'error'
             ])
        && data.status in ['converted', 'abandoned', 'failed', 'completed', 'blocked']
        && previous.status == 'open'
        && data.endedAt == request.time
        && optStr(data, 'leadId', 60)
        && optStr(data, 'error', 300)
        && (!('messageCount' in data) || (data.messageCount is int && data.messageCount >= 0 && data.messageCount <= 500))
        && (!('durationSec' in data) || (data.durationSec is int && data.durationSec >= 0 && data.durationSec <= 86400))
        // The three Bit questions, capped per key — same rule as customAnswers on
        // a lead, so a close-out cannot become 1MB of free object storage either.
        && (!('answers' in data) || validCustomAnswers(data.answers));
    }

    function validTurn(data) {
      return data.keys().hasAll(['at'])
        && data.keys().hasOnly(['role', 'kind', 'text', 'state', 'questionKey', 'at'])
        && data.at == request.time
        && (!('role' in data) || data.role in ['visitor', 'bit', 'byte'])
        && (!('kind' in data) || data.kind in ['text', 'choice', 'prompt', 'system', 'state', 'transcript'])
        && optStr(data, 'text', 2000)
        && optStr(data, 'state', 40)
        && optStr(data, 'questionKey', 60);
    }

    match /chats/{chatId} {
      allow create: if validConversationOpen(request.resource.data, 'bit', 'chat');
      allow update: if isAdmin()
                    || validConversationClose(request.resource.data, resource.data);
      allow read:   if isAdmin();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow create: if validTurn(request.resource.data);
        allow read:   if isAdmin();
        allow update: if false;
        allow delete: if isAdmin();
      }
    }

    match /calls/{callId} {
      allow create: if validConversationOpen(request.resource.data, 'byte', 'voice');
      allow update: if isAdmin()
                    || validConversationClose(request.resource.data, resource.data);
      allow read:   if isAdmin();
      allow delete: if isAdmin();

      // Turns cover both the state timeline and any transcript the widget
      // renders. The authoritative transcript arrives server-side from the
      // GoHighLevel webhook, which runs with the Admin SDK and bypasses rules.
      match /turns/{turnId} {
        allow create: if validTurn(request.resource.data);
        allow read:   if isAdmin();
        allow update: if false;
        allow delete: if isAdmin();
      }
    }

    // ------------------------------------------------------------------ roles
    // The authoritative access-control store. Deliberately unwritable by the
    // account it describes — bootstrap your first admin from the Firebase console.
    //
    // No client may write this, not even an admin. A role is two things that
    // have to move together: this document, and the `role` custom claim that
    // role() below reads *first*. A browser can only ever write one of them, and
    // a half-applied revoke leaves a claim still saying "admin" — which is
    // exactly the state that looks revoked in the UI and isn't.
    //
    // So writes go through paths that hold the Admin SDK and set both halves:
    // the `setUserRole` callable (what the Users tab calls) or `npm run role`.
    // Both bypass these rules, so denying every client write costs nothing and
    // makes the desync unreachable rather than merely discouraged.

    match /roles/{uid} {
      allow read:  if isOwner(uid) || isAdmin();
      allow write: if false;
    }

    // ------------------------------------------------------------------ users
    // Self-service profile records created at sign-up.

    match /users/{uid} {
      function validProfile(data) {
        return data.keys().hasOnly([
                 'email', 'displayName', 'company', 'phone',
                 'status', 'createdAt', 'updatedAt'
               ])
          && str(data, 'email', 200)
          && optStr(data, 'displayName', 120)
          && optStr(data, 'company', 160)
          && optStr(data, 'phone', 40);
      }

      allow read: if isOwner(uid) || isAdmin();

      // A new account may only ever describe itself, and always starts pending.
      allow create: if isOwner(uid)
                    && validProfile(request.resource.data)
                    && request.resource.data.email == request.auth.token.email
                    && request.resource.data.status == 'pending'
                    && request.resource.data.createdAt == request.time;

      // Users edit their own contact details; only an admin moves them out of
      // "pending" (approval) — status is immutable to the account holder.
      allow update: if isAdmin()
                    || (isOwner(uid)
                        && validProfile(request.resource.data)
                        && request.resource.data.status == resource.data.status
                        && request.resource.data.email == resource.data.email);

      allow delete: if isAdmin();
    }

    // --------------------------------------------------------------- projects
    // Client portal records. Admins manage them; an approved client sees only
    // the projects their uid is listed on.

    match /projects/{projectId} {
      allow read:  if isAdmin()
                   || (isClient() && request.auth.uid in resource.data.clientUids);
      allow write: if isAdmin();
    }

    // Anything not matched above is denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
