{
  "name": "bitesites-react-node",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check": "npm run build",
    "secrets:check": "node scripts/check-no-secrets.mjs",
    "deploy": "npm run build && firebase deploy --only hosting,firestore",
    "deploy:hosting": "npm run build && firebase deploy --only hosting",
    "deploy:rules": "firebase deploy --only firestore:rules,firestore:indexes",
    "deploy:functions": "firebase deploy --only functions",
    "emulators": "firebase emulators:start",
    "test:rules": "firebase emulators:exec --only firestore --project demo-bitesites \"node scripts/test-rules.mjs\"",
    "test:voice": "firebase emulators:exec --only firestore --project demo-bitesites \"node functions/voice-webhook.test.mjs\"",
    "test:import": "firebase emulators:exec --only firestore --project demo-bitesites \"node functions/voice-import.test.mjs\"",
    "role": "node scripts/set-role.mjs",
    "ship": "sh scripts/ship.sh",
    "start": "node server.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "express": "^5.1.0",
    "firebase": "^12.16.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.18.1",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "firebase-admin": "^14.2.0",
    "playwright": "^1.61.1",
    "vite": "^6.3.5"
  }
}
